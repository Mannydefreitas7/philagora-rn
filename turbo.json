{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalDependencies": [".env.development"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env.development"],
    },
    "check-types": {
      "dependsOn": ["^check-types"],
    },
    "dev": {
      "cache": false,
      "persistent": true,
    },
    "clean": {
      "cache": false,
    },
  },
}
