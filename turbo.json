{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalDependencies": [
    ".env.development"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "cache": true
    },
    "types:generate": {
      "cache": true,
      "dependsOn": [
        "^types:generate",
        "build"
      ]
    },
    "check-types": {
      "dependsOn": [
        "^check-types"
      ]
    },
    "clean": {
      "cache": false
    }
  }
}
