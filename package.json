{
  "name": "philagora",
  "private": true,
  "scripts": {
    "setup": "bun run clean && bun install",
    "build": "dotenvx run -f .env.development -- turbo run build",
    "start": "dotenvx run -f .env.development -- turbo run @repo/mobile#start",
    "encrypt": "dotenvx encrypt -f .env.development",
    "decrypt": "dotenvx decrypt -fk .env.keys -f .env.development",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "cache:clear": "watchman watch-del-all",
    "clean": "rm -rf node_modules .turbo bun.lock && turbo run clean",
    "biome:format": "bunx --bun @biomejs/biome format --write",
    "biome:lint": "bunx --bun @biomejs/biome lint --write",
    "biome:check": "bunx --bun @biomejs/biome check --write --max-diagnostics=50"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@dotenvx/dotenvx": "^1.52.0",
    "supabase": "^2.76.16",
    "turbo": "^2.8.13",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.9",
  "trustedDependencies": [
    "uniwind",
    "react"
  ],
  "workspaces": {
    "packages": [
      "packages/*",
      "apps/*"
    ],
    "catalogs": {
      "testing": {
        "jest": "^29.7.0",
        "testing-library": "^14.1.0"
      },
      "ui": {
        "postcss": "^8.5.6",
        "tailwindcss": "^4.2.0",
        "heroui-native": "^1.0.0-rc.2",
        "@gorhom/bottom-sheet": "^5",
        "tailwind-merge": "^3.5.0",
        "tailwind-variants": "^3.2.2",
        "iconsax-react-nativejs": "^0.0.8",
        "@shopify/react-native-skia": "^2.4.21"
      },
      "expo": {
        "expo-router": "~55.0.3",
        "expo-blur": "~55.0.8",
        "expo": "~55.0.00",
        "expo-linear-gradient": "~55.0.8",
        "expo-image": "~55.0.5"
      },
      "development": {
        "typescript": "^5.9.3",
        "@types/node": "^22.15.3",
        "@types/react": "~19.2.10",
        "@types/react-dom": "~19.1.7",
        "immer": "^11.1.4",
        "add": "^2.0.6",
        "zustand-x": "^6.2.1",
        "use-immer": "^0.11.0",
        "@davstack/store": "^1.4.6",
        "zustand": "^5.0.11"
      },
      "react": {
        "react": "19.2.0",
        "react-dom": "19.2.0",
        "react-native": "0.83.2",
        "react-native-gesture-handler": "~2.30.0",
        "react-native-reanimated": "4.2.1",
        "react-native-safe-area-context": "~5.6.0",
        "react-native-screens": "~4.23.0",
        "react-native-svg": "15.15.3",
        "react-native-web": "^0.21.2",
        "react-native-uuid": "^2.0.3",
        "react-native-worklets": "0.7.2",
        "react-native-nitro-modules": "^0.33.9",
        "@reduxjs/toolkit": "^2.11.2",
        "react-redux": "^9.2.0",
        "@react-native-async-storage/async-storage": "2.2.0",
        "react-native-svg-transformer": "^1.5.3",
        "react-native-keyboard-controller": "^1.20.7"
      }
    }
  }
}
