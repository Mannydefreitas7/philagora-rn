{
	"name": "philagora",
	"private": true,
	"scripts": {
		"setup": "bun run clean && bun install",
		"build": "dotenvx run -f .env.development -- turbo run build",
		"start": "dotenvx run -f .env.development -- turbo run @repo/mobile#start @repo/server#start",
		"encrypt": "dotenvx encrypt -f .env.development",
		"decrypt": "dotenvx decrypt -fk .env.keys -f .env.development",
		"lint": "turbo run lint",
		"types:generate": "dotenvx run -f .env.development -- turbo run types:generate",
		"check-types": "turbo run check-types",
		"cache:clear": "watchman watch-del-all",
		"clean": "rm -rf node_modules .turbo bun.lock && turbo run clean",
		"biome:format": "bunx --bun @biomejs/biome format --write",
		"biome:lint": "bunx --bun @biomejs/biome lint --write",
		"biome:check": "bunx --bun @biomejs/biome check --write --max-diagnostics=50"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@dotenvx/dotenvx": "^1.54.1",
		"turbo": "^2.8.16",
		"typescript": "^5.9.3",
		"react-native-error-boundary": "^3.1.0"
	},
	"engines": {
		"node": ">=18"
	},
	"packageManager": "bun@1.3.9",
	"trustedDependencies": [
		"uniwind",
		"react"
	],
	"workspaces": {
		"packages": [
			"packages/*",
			"apps/*"
		],
		"catalogs": {
			"testing": {
				"jest": "^29.7.0",
				"testing-library": "^14.1.0",
				"@types/jest": "30.0.0",
				"jest-expo": "~55.0.9",
				"@testing-library/react-native": "^13.3.3"
			},
			"ui": {
				"heroui-native": "^1.0.0-rc.2",
				"@gorhom/bottom-sheet": "^5",
				"@gorhom/portal": "^1.0.14",
				"tailwind-merge": "^3.5.0",
				"tailwind-variants": "^3.2.2",
				"tailwindcss": "^4.2.1",
				"iconsax-react-nativejs": "^0.0.8",
				"lottie-react-native": "^7.3.6",
				"uniwind": "npm:uniwind-pro@rc",
				"@shopify/react-native-skia": "^2.4.21"
			},
			"expo": {
				"expo-notifications": "~55.0.12",
				"expo-router": "~55.0.5",
