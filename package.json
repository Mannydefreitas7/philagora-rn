{
  "name": "philagora",
  "private": true,
  "scripts": {
    "setup": "bun run clean && bun install",
    "build": "dotenvx run -f .env.development -- turbo run build",
    "start": "dotenvx run -f .env.development -- turbo run start",
    "dev": "dotenvx run -f .env.development -- turbo run dev",
    "encrypt": "dotenvx encrypt -f .env.*",
    "decrypt": "dotenvx decrypt -fk .env.keys -f .env.*",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "cache:clear": "watchman watch-del-all",
    "clean": "rm -rf node_modules .turbo bun.lock && turbo run clean",
    "postinstall": "turbo run @repo/mobile#prebuild"
  },
  "devDependencies": {
    "turbo": "^2.8.11",
    "typescript": "^5.9.3",
    "@dotenvx/dotenvx": "^1.52.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.9",
  "trustedDependencies": [
    "uniwind"
  ],
  "workspaces": {
    "packages": [
      "packages/*",
      "apps/*"
    ],
    "catalogs": {
      "testing": {
        "jest": "^29.7.0",
        "testing-library": "^14.1.0"
      },
      "ui": {
        "postcss": "^8.5.6",
        "tailwindcss": "^4.2.0",
        "heroui-native": "^1.0.0-rc.2",
        "@gorhom/bottom-sheet": "^5",
        "tailwind-merge": "^3.5.0",
        "tailwind-variants": "^3.2.2",
        "iconsax-react-nativejs": "^0.0.8"
      },
      "development": {
        "typescript": "^5.9.3",
        "@types/node": "^22.15.3",
        "@types/react": "~19.1.10",
        "@types/react-dom": "~19.1.7",
        "immer": "^11.1.4",
        "zustand": "^5.0.11"
      },
      "react": {
        "react": "19.1.0",
        "react-dom": "19.1.0",
        "react-native": "0.81.5",
        "react-native-gesture-handler": "~2.28.0",
        "react-native-reanimated": "~4.1.1",
        "react-native-safe-area-context": "^5.6.2",
        "react-native-screens": "~4.16.0",
        "react-native-svg": "15.12.1",
        "react-native-web": "^0.21.2",
        "react-native-uuid": "^2.0.3",
        "react-native-worklets": "0.5.1",
        "react-native-nitro-modules": "^0.33.9",
        "@react-native-async-storage/async-storage": "^3.0.1",
        "react-native-svg-transformer": "^1.5.3"
      }
    }
  }
}
