  },
  "dependencies": {
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "heroui-native": "catalog:ui",
    "lottie-react-native": "catalog:ui",
    "react-native": "catalog:react",
    "react-native-reanimated": "catalog:react",
    "@shopify/react-native-skia": "catalog:ui",
    "expo-blur": "catalog:expo",
    "react-native-worklets": "catalog:react",
    "react-native-svg": "catalog:react",
    "expo": "catalog:expo",
    "expo-image": "catalog:expo",
    "expo-router": "catalog:expo",
    "expo-linear-gradient": "catalog:expo",
    "react-native-pager-view": "8.0.0",
    "react-native-uuid": "catalog:react",
    "iconsax-react-nativejs": "catalog:ui"
