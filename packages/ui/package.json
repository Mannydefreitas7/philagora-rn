{
  "name": "@repo/ui",
  "version": "0.0.0",
  "private": true,
  "main": "dist/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./lib/index.d.ts"
    }
  },
  "files": [
    "dist",
    "lib"
  ],
  "scripts": {
    "build": "tsc",
    "generate:component": "turbo gen react-component",
