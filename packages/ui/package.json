{
  "name": "@repo/ui",
  "version": "0.0.0",
  "private": true,
  "main": "dist/index.js",
  "types": "lib/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./lib/index.d.ts"
    },
    "./base/*": "./dist/base/*",
    "./molecules/*": "./dist/molecules/*",
    "./organisms/*": "./dist/organisms/*"
  },
  "files": [
    "dist",
    "lib"
  ],
  "imports": {
    ".": [
      "./src/index.ts"
    ],
    "#base": [
      "./src/base/index.ts"
    ],
    "#base/icons": [
      "./src/base/icons/index.ts"
    ],
    "#molecules": [
      "./src/molecules/index.ts"
    ],
    "#organisms": [
      "./src/organisms/index.ts"
    ]
  },
  "scripts": {
    "build": "tsc",
    "generate:component": "turbo gen react-component",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf .turbo node_modules"
  },
  "devDependencies": {
    "typescript": "catalog:development",
    "@types/node": "catalog:development",
    "@types/react": "catalog:development",
    "@types/react-dom": "catalog:development",
    "@repo/configs": "workspace:*",
    "@repo/typings": "workspace:*",
    "@repo/utils": "workspace:*",
    "use-immer": "catalog:development"
  },
  "dependencies": {
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "heroui-native": "catalog:ui",
    "@gorhom/bottom-sheet": "catalog:ui",
    "@gorhom/portal": "catalog:ui",
    "lottie-react-native": "catalog:ui",
    "react-native": "catalog:react",
    "react-native-reanimated": "catalog:react",
    "@shopify/react-native-skia": "catalog:ui",
    "expo-blur": "catalog:expo",
    "react-native-worklets": "catalog:react",
    "react-native-svg": "catalog:react",
    "expo": "catalog:expo",
    "expo-image": "catalog:expo",
    "expo-router": "catalog:expo",
    "expo-linear-gradient": "catalog:expo",
    "react-native-pager-view": "8.0.0",
    "react-native-uuid": "catalog:react",
    "iconsax-react-nativejs": "catalog:ui"
  }
}
