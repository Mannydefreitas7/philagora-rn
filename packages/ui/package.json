    "clean": "rm -rf dist lib .turbo node_modules"
  },
  "devDependencies": {
    "typescript": "catalog:development",
    "@types/node": "catalog:development",
    "@types/react": "catalog:development",
    "@types/react-dom": "catalog:development",
