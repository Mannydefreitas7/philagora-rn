    "@testing-library/react-native": "catalog:testing",
    "jest": "catalog:testing",
    "jest-expo": "catalog:testing",
    "@types/jest": "catalog:testing",
    "tsup": "^8.5.0",
    "use-immer": "catalog:development"
  },
  "dependencies": {
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "heroui-native": "catalog:ui",
