{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@repo/configs/ts/expo",
  "compilerOptions": {
    "rootDir": "./src",
    "jsx": "react-jsx",
    "noEmit": true,
    "emitDeclarationOnly": true,
    "resolveJsonModule": true,
    "module": "esnext",
    "baseUrl": ".",
    "declarationDir": "lib",
    "moduleResolution": "bundler",
    "target": "esnext",
    "strict": true,
    "paths": {
      "~/organisms/*": [
        "./src/organisms/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "dist",
    "tsup.config.ts"
  ]
}
