{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "outDir": "lib",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "src/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "**/types/*.ts",
    "types/*.ts"
  ],
  "exclude": [
    "node_modules",
    "lib"
  ]
}
