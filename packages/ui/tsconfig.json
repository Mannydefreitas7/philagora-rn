{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@repo/configs/ts/expo",
  "compilerOptions": {
    "rootDir": "./src",
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "module": "esnext",
    "outDir": "dist",
    "baseUrl": ".",
    "declarationDir": "lib",
    "moduleResolution": "bundler",
    "target": "esnext",
    "strict": false,
    "paths": {
      "~/base/*": [
        "./src/base/*"
      ],
      "~/molecules/*": [
        "./src/molecules/*"
      ],
      "~/organisms/*": [
        "./src/organisms/*"
      ],
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "dist",
    "lib"
  ]
}
