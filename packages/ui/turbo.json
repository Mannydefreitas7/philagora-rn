{
  "$schema": "https://turborepo.dev/schema.json",
  "extends": [
    "//"
  ],
  "tasks": {
    "build": {
      "cache": false,
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        "lib/**"
      ]
    },
    "check-types": {
      "dependsOn": [
        "^check-types"
      ]
    },
    "start": {
      "cache": false,
      "persistent": false,
      "dependsOn": [
        "build"
      ]
    }
  }
}
