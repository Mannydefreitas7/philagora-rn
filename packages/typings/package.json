{
  "name": "@repo/typings",
  "description": "Typings for the project",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./user": "./src/user.ts",
    "./database": "./src/database.ts",
    "./auth": "./src/auth.ts"
  },
  "scripts": {
    "clean": "rm -rf .turbo node_modules",
    "types:generate": "supabase gen types --lang=typescript --local > src/database.ts --workdir=$EXPO_PUBLIC_SUPABASE_DIR"
  },
  "dependencies": {
    "expo-router": "catalog:expo"
  },
  "devDependencies": {
    "tailwindcss": "catalog:ui",
    "supabase": "^2.77.0",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "react-native": "catalog:react",
    "typescript": "catalog:development",
    "@types/node": "catalog:development",
    "@types/react": "catalog:development",
    "@types/react-dom": "catalog:development"
  }
}
