{
  "$schema": "https://turborepo.dev/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "cache": true,
      "dependsOn": ["^build", "ios"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "prebuild": {
      "cache": true,
      "outputs": ["ios", "android"]
    },
    "start": {
      "cache": false,
      "persistent": true,
      "with": ["@repo/server#start"]
    },
    "ios": {
      "cache": true
    },
    "android": {
      "cache": true
    },
  },
}
