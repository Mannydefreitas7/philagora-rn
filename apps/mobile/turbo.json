{
  "extends": ["//"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true,
    },
    "build": {
      "dependsOn": ["^build", "ios"],
    },
    "check-types": {
      "dependsOn": ["^check-types"],
    },
    "prebuild": {
      "cache": false,
      "outputs": ["ios", "android"],
    },
    "start": {
      "cache": false,
      "persistent": true,
      "with": ["@repo/server#start"],
    },
    "ios": {
      "cache": true,
    },
    "android": {
      "cache": true,
    },
  },
}
